# MongoDB — local หรือ Atlas (Atlas รองรับ Vector Search; local ใช้ in-app cosine fallback)
MONGODB_URI=mongodb+srv://messagetagger:B2pBmwNZHk9cL6RJ@wegivdev.uyobx.mongodb.net/messageTag

# Google Gemini API — ใช้ key เดียวทั้ง tagging และ embeddings
# ถ้าไม่ใส่ ระบบจะ fallback เป็น mock tagger + pseudo-embedding อัตโนมัติ
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# Session secret สำหรับเซ็นคุกกี้ล็อกอิน
AUTH_SECRET=dev-secret-change-me-in-production

# LINE Messaging API
# ตั้ง LINE_CHANNEL_SECRET เพื่อบังคับตรวจ X-Line-Signature (ถ้าเว้นว่าง = ข้ามตรวจ สำหรับ dev)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
# LINE_AUTO_TAG=1 เพื่อให้ AI ติดแท็กอัตโนมัติเมื่อมีข้อความใหม่จาก LINE
LINE_AUTO_TAG=0
